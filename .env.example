# Example environment variables

# Backend
SPRING_PROFILES_ACTIVE=postgres
SERVER_PORT=3002
# Use the exact env var name expected by application-postgres.properties
POSTGRES_URL=jdbc:postgresql://localhost:5433/tunetrivia

# Google OAuth (placeholders)
GOOGLE_CLIENT_ID=asdasdasd1231231231.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=asdasdasdasdasd
GOOGLE_REDIRECT_URI=http://localhost:3002/api/auth/callback

# JWT
JWT_SECRET=asdasdasdasdas
JWT_EXPIRATION_MS=3600000

POSTGRES_USER=tunetrivia
POSTGRES_PASSWORD=tunetrivia
